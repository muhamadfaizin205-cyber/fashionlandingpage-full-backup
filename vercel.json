{
  "crons": [
    {
      "path": "/api/auto-article",
      "schedule": "0 9 */2 * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "query", "key": "q" }],
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/articles/:slug", "destination": "/api/article-ssr?slug=:slug" },
    { "source": "/articles", "destination": "/index.html" },
    { "source": "/gigs", "destination": "/index.html" },
    { "source": "/my-orders", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
